# Microsoft 365 Email Configuration (optional -- choose M365 or Resend)
# Copy this file to .env and update with your actual credentials
# Never commit .env to version control!

# Entra App Registration Details
M365_CLIENT_ID=your-client-id-here
M365_CLIENT_SECRET=your-client-secret-here
M365_TENANT_ID=common

# M365 Email Configuration
SENDER_EMAIL=your-sender@example.com
NOTIFICATION_RECIPIENTS=your-email@example.com

# Resend Email Configuration (alternative to M365)
# Sign up at https://resend.com and verify your domain
# RESEND_API_KEY=re_xxxxxxxxxx
# RESEND_FROM_EMAIL=notifications@yourdomain.com

# Admin Configuration
ADMIN_PASSWORD=change-me-to-a-secure-password
ADMIN_JWT_SECRET=change-me-to-a-random-secret

# Site URL (used for email links and subscription management)
SITE_URL=https://yourdomain.com

# Optional: Analytics (e.g. Plausible)
# PLAUSIBLE_DOMAIN=yourdomain.com
# PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# Optional: Contact email shown in the UI
# CONTACT_EMAIL=support@example.com

# Optional: Override Graph API endpoints (usually not needed)
# GRAPH_API_URL=https://graph.microsoft.com/v1.0
# TOKEN_URL=https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token