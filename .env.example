# -----------------------------------------------------------------------------
# App Tracker - example environment configuration
# Copy to `.env` and edit. All variables are optional unless marked REQUIRED.
# -----------------------------------------------------------------------------

# -- Core ---------------------------------------------------------------------

# Flask session secret. REQUIRED in production. Generate with:
#   openssl rand -hex 32
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Admin user password (seeded on first boot with username "admin").
ADMIN_PASSWORD=change-me

# Secret used to sign admin session JWTs. REQUIRED in production.
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# Brute-force protection for /admin/login (all optional; defaults shown).
# ADMIN_LOGIN_RATE_LIMIT uses Flask-Limiter syntax: "N per minute;N per hour".
#ADMIN_LOGIN_RATE_LIMIT=5 per minute;30 per hour
#ADMIN_MAX_FAILED_ATTEMPTS=10
#ADMIN_LOCKOUT_MINUTES=15

# Number of reverse proxies in front of the app (for ProxyFix -> real client
# IP in rate limiter and logs). 1 = single nginx in front. Set to 2 if you
# also sit behind Cloudflare and want Cloudflare's CF-Connecting-IP honoured.
#TRUSTED_PROXY_COUNT=1

# Public base URL where this site is reachable, used in email links.
# e.g. https://tracker.example.com
SITE_URL=https://localhost

# Set to "true" to mount under /app-tracker-dev and disable the scheduler.
DEV_MODE=false

# SQLite locations (defaults are fine for the bundled docker-compose).
DB_PATH=/data/microsoft_apps_versions.db
SUBSCRIPTION_DB_PATH=/data/subscriptions.db

# -- Branding / white-labelling -----------------------------------------------

# Product / tracker name. Shown in h1, <title>, emails, and copyright.
SITE_NAME=Mac Apps Version Tracker

# Parent brand shown in the site header (top-left). Defaults to SITE_NAME.
# Useful when the tracker is embedded inside a larger site.
#BRAND_NAME=My Company Tools

# Where the brand text in the header links to.
BRAND_URL=/

# Navigation links, as a JSON array. Each item: {label, href, target?, match?}
# "match" is an optional path prefix used for the active-state highlight
# (defaults to href). Use target="_blank" for external links.
#NAV_LINKS_JSON=[{"label":"App Tracker","href":"/","match":"/"},{"label":"Notifications","href":"/subscribe"},{"label":"JSON API","href":"/api/latest","target":"_blank"}]

# Optional footer logo. When empty, the logo row is hidden.
#FOOTER_LOGO_URL=/static/img/footer-logo.svg
#FOOTER_LOGO_ALT=My Brand

# Optional attribution line shown next to the footer logo. Hidden when empty.
#FOOTER_ATTRIBUTION=Maintained by the Community

# Tagline (HTML allowed) under the logo row. Defaults to a generic blurb.
#FOOTER_TAGLINE_HTML=Independent, open-source tooling.

# Disclaimer card in the footer.
#FOOTER_DISCLAIMER_TITLE=About This Tracker
#FOOTER_DISCLAIMER_HTML=<p>Independent, not affiliated with any vendor.</p>

# Footer link list, JSON array: {label, href, target?}
#FOOTER_LINKS_JSON=[{"label":"Notifications","href":"/subscribe"},{"label":"JSON API","href":"/api/latest","target":"_blank"}]

# Brand name used in outgoing email subjects/bodies. Defaults to SITE_NAME.
#EMAIL_BRAND_NAME=Mac Apps Version Tracker

# -- Template / static overrides ----------------------------------------------

# To fully replace `_header.html`, `_footer.html`, or any other template,
# mount a directory into the container and point this at it:
#TEMPLATE_OVERRIDE_DIR=/app/templates_override
# (see docker-compose.yml for a volume mount example)

# -- Analytics / contact ------------------------------------------------------

#PLAUSIBLE_DOMAIN=tracker.example.com
#PLAUSIBLE_SCRIPT_URL=https://plausible.example.com/js/script.js
#CONTACT_EMAIL=admin@example.com

# -- Email provider -----------------------------------------------------------
# Configure your SMTP / SendGrid / etc. credentials here.
# See notifications/providers.py for supported providers.
